# ──────────────────────────────────────────────────────────────
# ConnectHub Frontend — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your values:
#   cp .env.example .env
#
# NOTE: Only variables prefixed with VITE_ are exposed to
# the frontend code. This is a Vite security feature — it
# prevents accidentally leaking server-side secrets to the
# browser.
# ──────────────────────────────────────────────────────────────

# Backend API URL (where your Express server is running)
# Development default: http://localhost:5000/api
# Production example:  https://api.connecthub.yourdomain.com/api
VITE_API_URL=http://localhost:5000/api

# Socket.io server URL (usually same host as API, without /api)
VITE_SOCKET_URL=http://localhost:5000

# Base URL for serving static files (avatars, chat uploads)
VITE_BASE_URL=http://localhost:5000
