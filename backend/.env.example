# ──────────────────────────────────────────────────────────────
# ConnectHub Backend — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your actual .env file to git!
# ──────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/connecthub

# Authentication
JWT_SECRET=change_this_to_a_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# CORS — which frontend URL is allowed to make requests
# In production, set this to your actual frontend domain
CORS_ORIGIN=http://localhost:5173

# File upload limits (in bytes)
# MAX_FILE_SIZE=20971520      # 20MB (default)
# MAX_AVATAR_SIZE=5242880     # 5MB (default)

# Rate limiting
# RATE_LIMIT_WINDOW_MS=900000         # 15 minutes (default)
# RATE_LIMIT_AUTH_MAX=10              # Auth attempts per window (default)
# RATE_LIMIT_UPLOAD_MAX=20            # Uploads per window (default)
# RATE_LIMIT_GENERAL_MAX=100          # General requests per window (default)

# Redis (required for horizontal scaling — optional for single-server dev)
# REDIS_URL=redis://localhost:6379

# TURN server (required for reliable WebRTC behind NATs/firewalls)
TURN_URL=turn:localhost:3478
TURN_SECRET=change_this_to_your_coturn_static_auth_secret
